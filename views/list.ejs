<!DOCTYPE html>
<html>
<head>
    <title>Spending List</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/navbar') %>
<form action="/spendings" method="GET" class="mb-3">
    <div class="row">
        <div class="col-md-10">
            <input
                type="text"
                name="search"
                class="form-control"
                placeholder="Search by item or category"
                value="<%= search || '' %>"
            >
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">
                Search
            </button>
        </div>
    </div>
</form>
    <div class="container">
        <h1>Spending List</h1>
        <p class="text-muted">All my spending records are shown here.</p>


        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Item</th>
                    <th>Category</th>
                    <th>Amount</th>
                    <th>Date</th>
                    <th>Favourite</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% spendings.forEach(spending => { %>
                    <tr class="<%= spending.favourite ? 'table-warning' : '' %>">
                        <td><%= spending.item %></td>
                        <td><%= spending.category %></td>
                        <td>$<%= Number(spending.amount).toFixed(2) %></td>
                        <td><%= spending.date %></td>
                        <td><%= spending.favourite ? '⭐ Yes' : 'No' %></td>
                        <td>
                            <a href="/spendings/<%= spending.id %>" class="btn btn-info btn-sm">Details</a>
                            <a href="/edit/<%= spending.id %>" class="btn btn-warning btn-sm">Edit</a>
                            <form action="/delete/<%= spending.id %>" method="POST" style="display:inline;">
                                <button class="btn btn-danger btn-sm">Delete</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <div class="container mt-4">
        <a href="/" class="btn btn-secondary">Back</a>
    </div>
</body>
</html>
