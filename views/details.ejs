<!DOCTYPE html>
<html>
<head>
    <title>Spending Details</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container">
        <h1>Spending Details</h1>

        <div class="card p-4">
            <p><strong>Item:</strong> <%= spending.item %></p>
            <p><strong>Category:</strong> <%= spending.category %></p>
            <p><strong>Amount:</strong> $<%= Number(spending.amount).toFixed(2) %></p>
            <p><strong>Date:</strong> <%= spending.date %></p>
            <p><strong>Notes:</strong> <%= spending.notes || 'No notes added.' %></p>
            <p><strong>Favourite:</strong> <%= spending.favourite ? '⭐ Yes' : 'No' %></p>
        </div>

        <a href="/spendings" class="btn btn-secondary mt-3">Back</a>
    </div>
    <div class="container mt-4">
        <a href="/" class="btn btn-secondary">Back</a>
    </div>
</body>
</html>
