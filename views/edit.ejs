<!DOCTYPE html>
<html>
<head>
    <title>Edit Spending</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container">
        <h1>Edit Spending</h1>

        <form action="/edit/<%= spending.id %>" method="POST" class="card p-4">
            <label class="form-label">Item</label>
            <input type="text" name="item" class="form-control mb-3" value="<%= spending.item %>" required>

            <label class="form-label">Category</label>
            <select name="category" class="form-control mb-3" required>
                <% ['Food', 'Transport', 'Shopping', 'Toys', 'School', 'Others'].forEach(category => { %>
                    <option <%= spending.category === category ? 'selected' : '' %>><%= category %></option>
                <% }) %>
            </select>

            <label class="form-label">Amount</label>
            <input type="number" name="amount" class="form-control mb-3" step="0.01" min="0" value="<%= spending.amount %>" required>

            <label class="form-label">Date</label>
            <input type="date" name="date" class="form-control mb-3" value="<%= spending.date %>" required>

            <label class="form-label">Notes</label>
            <textarea name="notes" class="form-control mb-3" rows="3"><%= spending.notes %></textarea>

            <div class="form-check mb-3">
                <input type="checkbox" name="favourite" class="form-check-input" id="favourite" <%= spending.favourite ? 'checked' : '' %>>
                <label class="form-check-label" for="favourite">Mark as favourite item</label>
            </div>

            <div>
                <button class="btn btn-warning">Update Spending</button>
                <a href="/spendings" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
    <div class="container mt-4">
        <a href="/" class="btn btn-secondary">Back</a>
    </div>
</body>
</html>
