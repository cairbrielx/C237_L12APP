<!DOCTYPE html>
<html>
<head>
    <title>Add Spending</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container">
        <h1>Add Spending</h1>

        <form action="/add" method="POST" class="card p-4">
            <label class="form-label">Item</label>
            <input type="text" name="item" class="form-control mb-3" required>

            <label class="form-label">Category</label>
            <select name="category" class="form-control mb-3" required>
                <option>Food</option>
                <option>Transport</option>
                <option>Shopping</option>
                <option>Toys</option>
                <option>School</option>
                <option>Others</option>
            </select>

            <label class="form-label">Amount</label>
            <input type="number" name="amount" class="form-control mb-3" step="0.01" min="0" required>

            <label class="form-label">Date</label>
            <input type="date" name="date" class="form-control mb-3" required>

            <label class="form-label">Notes</label>
            <textarea name="notes" class="form-control mb-3" rows="3"></textarea>

            <div class="form-check mb-3">
                <input type="checkbox" name="favourite" class="form-check-input" id="favourite">
                <label class="form-check-label" for="favourite">Mark as favourite item</label>
            </div>

            <div>
                <button class="btn btn-success">Add Spending</button>
                <a href="/spendings" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
    <div class="container mt-4">
        <a href="/" class="btn btn-secondary">Back</a>
    </div>
</body>
</html>
