<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>My Simple Application</title>
</head>
<body>
    <title>Spending Tracker</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
      <style>
    .favourite-card a {
        transition: color 0.2s ease;
    }

    .favourite-card a:hover {
        color: #4aa4f3 !important;
    }
</style>
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container">
        <div class="p-5 bg-light rounded-3">
            <h1>My Spending Tracker</h1>
            <p class="lead">This app helps me record what I spend on, the category, amount, date, and short notes.</p>
            <a href="/spendings" class="btn btn-primary">View Spending List</a>
            <a href="/add" class="btn btn-success">Add New Spending</a>
        </div>

        <div class="row mt-4">
            <div class="col-md-4">
                <div class="card p-3">
                    <h5>Total Records</h5>
                    <p class="fs-4"><%= totalItems %></p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-3">
                    <h5>Total Spent</h5>
                    <p class="fs-4">$<%= totalAmount.toFixed(2) %></p>
                </div>
            </div>
            <div class="col-md-4">
    <div class="card p-3 favourite-card">
        <a href="/favourite" class="text-decoration-none text-dark">
            <h5>Favourite Items</h5>
        </a>
        <p class="fs-4"><%= favouriteCount %></p>
    </div>
</div>
            </div>
        </div>
    </div>
</body>
</html>