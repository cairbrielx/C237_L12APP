<!DOCTYPE html>
<html>
<head>
    <title>Favourite Items</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container">
        <h1>Favourite Items</h1>
        <p>Here are your favourite spending items:</p>

        <div class="row">
            <% spendings.filter(spending => spending.favourite).forEach(spending => { %>
                <div class="col-md-4 mb-3">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title"><%= spending.item %></h5>
                            <p class="card-text">Category: <%= spending.category %></p>
                            <p class="card-text">Amount: $<%= spending.amount.toFixed(2) %></p>
                            <p class="card-text">Date: <%= spending.date %></p>
                            <p class="card-text">Notes: <%= spending.notes %></p>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>
    <div class="container mt-4">
        <a href="/" class="btn btn-secondary">Back</a>
    </div>
</body>
</html>